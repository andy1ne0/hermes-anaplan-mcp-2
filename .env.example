# Basic Auth credentials (not OAuth)
ANAPLAN_USERNAME=your.email@example.com
ANAPLAN_PASSWORD=your_password

# Optional: ANAPLAN_MCP_HTTP_AUTH_TOKEN=***
# Optional: ANAPLAN_MCP_HTTP_BODY_LIMIT=100mb

# Playwright UI automation (for operations blocked by API v2.0 limitations)
# Enable to use browser automation as fallback for set_modelmode, create_list, create_module
# Requires: npm install playwright && npx playwright install chromium
ANAPLAN_PLAYWRIGHT_ENABLED=false
# ANAPLAN_PLAYWRIGHT_REGION=au1a          # Anaplan region: au1a, us1a, eu1a, etc.
# ANAPLAN_PLAYWRIGHT_HEADLESS=true         # Set to false for visual debugging